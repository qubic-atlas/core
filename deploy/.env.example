# Copy to .env and fill in.  (docker compose auto-loads .env from this directory)

# Cloudflare Tunnel connector token (Zero Trust → Networks → Tunnels → your tunnel → install token).
# The whole app is served ONLY through this tunnel.
CF_TUNNEL_TOKEN=

# Optional overrides
# QUBIC_RPC=https://rpc.qubic.org
# ATLAS_CONFIRMATIONS=2        # workers that must agree on the genome hash to confirm a Proof
# ATLAS_REQUIRE_SIGNED=true    # require SchnorrQ-signed worker submissions
# WORKER_REPLICAS=2            # local verifier workers (or use: docker compose up -d --scale worker=N)
