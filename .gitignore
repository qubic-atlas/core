# --- dependencies / build output ---
**/node_modules/
**/dist/
frontend/dist/

# --- .NET ---
**/bin/
**/obj/

# --- scorer: binaries + generated/experimental (coretree IS tracked; it's the patched build tree) ---
scorer/verifier
scorer/harness
scorer/annx_native
scorer/*.o
scorer/wasm/
scorer/coretree_wasm/
scorer/recon_out.json

# --- runtime data (regenerable / machine-local) ---
**/.cache/
backend/.index/
.index/

# --- secrets / local env ---
**/.env
deploy/.env
*.key
worker.key

# --- misc ---
.DS_Store
*.log
/tmp/

# historical build trees (regenerate: scorer/build_hist.sh <tag> <buildN>)
scorer/coretree_build*
scorer/verifier-build*
