<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Local Qubic.Crypto source. The nupkg is vendored into ./nupkgs so this
         resolves identically for `dotnet run` and inside the Docker build. -->
    <add key="qubic-local" value="./nupkgs" />
  </packageSources>
</configuration>
